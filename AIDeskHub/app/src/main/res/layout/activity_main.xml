<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/desk_background"
    android:padding="@dimen/screen_content_padding"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/kioskContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/institutionPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="20dp"
            android:layout_weight="3"
            android:background="@color/desk_surface"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:id="@+id/timeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/desk_primary_dark"
                android:textSize="56sp"
                android:textStyle="bold"
                tools:text="10:24" />

            <TextView
                android:id="@+id/dateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/desk_text_muted"
                android:textSize="20sp"
                tools:text="2026년 7월 2일 목요일" />

            <TextView
                android:id="@+id/weatherText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/weather_placeholder"
                android:textColor="@color/desk_accent"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/institutionNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="44dp"
                android:text="@string/institution_name"
                android:textColor="@color/desk_text"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/greetingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/kiosk_greeting"
                android:textColor="@color/desk_text"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/kioskHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/kiosk_hint"
                android:textColor="@color/desk_text_muted"
                android:textSize="17sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/listenButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="12dp"
                    android:layout_weight="1"
                    android:text="음성 인식" />

                <Button
                    android:id="@+id/sampleResultButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="샘플 안내" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/noticePanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:background="@color/desk_primary_dark"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="공지사항"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/noticePrimaryText"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="24dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/notice_1"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/noticeSecondaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notice_2"
                android:textColor="@color/desk_surface_muted"
                android:textSize="18sp" />

            <Button
                android:id="@+id/adminEntryButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:text="관리자 모드" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/resultContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/desk_surface"
        android:orientation="vertical"
        android:padding="28dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/resultTitleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="길 안내"
                android:textColor="@color/desk_text"
                android:textSize="28sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/closeResultButton"
                android:layout_width="64dp"
                android:layout_height="52dp"
                android:text="X" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/routeImagePlaceholder"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="18dp"
            android:layout_weight="1"
            android:background="@color/desk_surface_muted">

            <TextView
                android:id="@+id/routeStepText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="24dp"
                android:textColor="@color/desk_text_muted"
                android:textSize="24sp"
                tools:text="1층 로비에서 오른쪽 복도로 이동하세요." />
        </FrameLayout>

        <TextView
            android:id="@+id/resultAnswerText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/desk_text"
            android:textSize="20sp"
            tools:text="학생 식당은 본관 1층 동쪽 복도 끝에 있습니다." />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/desk_surface"
        android:orientation="vertical"
        android:padding="28dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="관리자 모드"
                android:textColor="@color/desk_text"
                android:textSize="30sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/adminExitButton"
                android:layout_width="120dp"
                android:layout_height="52dp"
                android:text="나가기" />
        </LinearLayout>

        <GridLayout
            android:id="@+id/adminMenuGrid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:layout_weight="1"
            android:columnCount="2"
            android:rowCount="2">

            <TextView
                style="@style/AdminMenuCard"
                android:text="기관 설정\n기관명, 테마, 인사말" />

            <TextView
                style="@style/AdminMenuCard"
                android:text="지식 데이터\n운영 시간, 연락처, FAQ" />

            <TextView
                style="@style/AdminMenuCard"
                android:text="길 안내 데이터\n도착지, 사진, 키워드" />

            <TextView
                style="@style/AdminMenuCard"
                android:text="Import / Export\nCSV, JSON 백업과 복원" />
        </GridLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/listeningOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/desk_overlay"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_gravity="bottom"
            android:background="@color/desk_surface"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/listeningStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="듣고 있어요"
                android:textColor="@color/desk_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/waveformText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="▁ ▃ ▅ ▇ ▅ ▃ ▁"
                android:textColor="@color/desk_primary"
                android:textSize="32sp" />
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
