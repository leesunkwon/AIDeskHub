<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AIDeskHub" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.AIDeskHub" parent="Base.Theme.AIDeskHub" />

    <style name="DisplayText">
        <item name="android:fontFamily">sans</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/desk_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CaptionText">
        <item name="android:fontFamily">sans</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/desk_text_muted</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="PillButtonPrimary">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:background">@drawable/bg_pill_primary</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:paddingStart">@dimen/button_horizontal_padding</item>
        <item name="android:paddingEnd">@dimen/button_horizontal_padding</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PillButtonSecondary">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:background">@drawable/bg_pill_secondary</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:paddingStart">@dimen/button_horizontal_padding</item>
        <item name="android:paddingEnd">@dimen/button_horizontal_padding</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/desk_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PillButtonOnDark">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:background">@drawable/bg_pill_on_dark</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:paddingStart">@dimen/button_horizontal_padding</item>
        <item name="android:paddingEnd">@dimen/button_horizontal_padding</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/desk_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AdminMenuCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_margin">@dimen/spacing_sm</item>
        <item name="android:background">@drawable/bg_flat_tile</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:padding">@dimen/spacing_xl</item>
        <item name="android:textColor">@color/desk_text</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
